# Branding
# NEXT_PUBLIC_APP_NAME=Formwise

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/adhera
# Optional: direct (non-pooled) connection used by Prisma for migrations. Falls back to DATABASE_URL if unset.
DIRECT_URL=

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=

# Pusher (real-time notifications)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=eu
NEXT_PUBLIC_PUSHER_KEY=
NEXT_PUBLIC_PUSHER_CLUSTER=eu

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Legacy single-product prices — still bill associations created before the
# Essentiel/Pro split (see scripts/migrate-existing-associations-to-tier.ts).
STRIPE_PRICE_MONTHLY=
STRIPE_PRICE_YEARLY=
# Populate by running: npx tsx scripts/stripe-setup-tiers.ts
STRIPE_PRICE_ESSENTIAL_MONTHLY=
STRIPE_PRICE_ESSENTIAL_YEARLY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Cloudflare R2 (file storage)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# Resend (email)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@yourdomain.com

# Groq (AI)
GROQ_API_KEY=

# LiveKit (video meetings + egress recording)
LIVEKIT_URL=wss://your-project.livekit.cloud
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
NEXT_PUBLIC_LIVEKIT_URL=wss://your-project.livekit.cloud

# Note: SMS (Twilio) credentials are configured per-association in Paramètres > Intégrations, not here.

# Cron
CRON_SECRET=

# Seed (prisma/seed.ts)
# SEED_SUPER_ADMIN_PASSWORD is required — the script throws if it's unset, on purpose,
# so a real/prod environment can never be seeded with a well-known dev default password.
SEED_SUPER_ADMIN_PASSWORD=
# Demo association + accounts (admin@demo.fr / membre@demo.fr) — only created when this
# is exactly "true". Leave unset in production.
SEED_DEMO_DATA=
SEED_ADMIN_PASSWORD=
SEED_MEMBRE_PASSWORD=
