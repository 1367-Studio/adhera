generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  SUPER_ADMIN
  ADMIN
  PRESIDENT
  TRESORIER
  SECRETAIRE
  MEMBRE
}

enum MembreStatus {
  PENDING
  ACTIF
  INACTIF
  SUSPENDU
}

enum CotisationStatus {
  EN_ATTENTE
  PAYE
  EXONERE
}

enum RsvpStatus {
  CONFIRME
  PROVAVEL
  INCERTO
  ABSENT
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  CANCELLED
  PAST_DUE
  SUSPENDED
}

// Drives the member limit and which modules default on (see src/lib/plan-limits.ts,
// src/lib/modules.ts) — independent from which Stripe Price actually bills the
// association. Associations created before the Essentiel/Pro split keep billing on the
// original single-product Price (STRIPE_PRICE_MONTHLY/YEARLY) but still get tagged
// ESSENTIAL/PRO here based on their member count (see scripts/migrate-existing-
// associations-to-tier.ts) so limits/features behave consistently for everyone.
enum AssociationPlan {
  ESSENTIAL
  PRO
}

enum MaterialStatus {
  DISPONIBLE
  EN_USE
  EN_MAINTENANCE
  HORS_SERVICE
  PERDU
}

enum LoanStatus {
  DEMANDE
  CONFIRME
  REFUSE
}

enum TriggerType {
  SCHEDULED_ONCE
  SCHEDULED_RECURRING
  EVENT_COTISATION_DUE
  EVENT_PAYMENT_OVERDUE
  EVENT_REMINDER
  RSVP_CONFIRMED
  MEMBER_CREATED
  MEMBER_BIRTHDAY
}

enum MessageChannel {
  EMAIL
  SMS
  BOTH
}

enum RuleStatus {
  ACTIVE
  PAUSED
  DONE
}

enum SondageStatus {
  BROUILLON
  ACTIF
  FERME
}

enum BoutiqueProduitStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum BoutiqueCommandeStatus {
  PENDING
  PAID
  CANCELLED
}

enum BoutiquePaymentMethod {
  STRIPE
  MANUAL
  ESPECES
  CHEQUE
  CB
  VIREMENT
}

enum MeetingStatus {
  SCHEDULED
  LIVE
  ENDED
  CANCELLED
}

enum MeetingType {
  AG
  BUREAU
  GENERALE
}

enum QuestionType {
  TEXT_SHORT
  TEXT_LONG
  SINGLE_CHOICE
  MULTIPLE_CHOICE
  RATING
  YES_NO
}

enum BankTransactionType {
  CREDIT
  DEBIT
}

enum BankTransactionStatus {
  UNMATCHED
  MATCHED
  PENDING
  IGNORED
  DUPLICATE
}

enum FinanceCategoryType {
  INCOME
  EXPENSE
}

enum IncomeSource {
  MANUAL
  STRIPE
  BANK_IMPORT
}

enum IncomeStatus {
  PENDING
  PAID
  CANCELLED
}

enum ExpenseStatus {
  DRAFT
  VALIDATED
  CANCELLED
}

enum MatchedBy {
  AUTO
  USER
}

enum DonorType {
  INDIVIDUAL
  COMPANY
}

// Catégories de l'organisme bénéficiaire cochées sur les Cerfa 11580 (2041-RD) et
// 16216 (2041-MEC-SD) — union des deux listes, utilisée pour l'attestation imprimée
// sur le reçu fiscal entreprise.
enum OrganismeCategory {
  ASSOCIATION_LOI_1901
  FONDATION_RECONNUE_UTILITE_PUBLIQUE
  FONDATION_UNIVERSITAIRE_PARTENARIALE
  FONDATION_ENTREPRISE
  MUSEE_DE_FRANCE
  AIDE_ALIMENTAIRE_SOCIALE
  AUTRE_INTERET_GENERAL
  ASSOCIATION_CULTUELLE_ALSACE_MOSELLE
  ETABLISSEMENT_ENSEIGNEMENT_SUPERIEUR
  ETABLISSEMENT_ENSEIGNEMENT_SUPERIEUR_CONSULAIRE
  ORGANISME_RECHERCHE_SCIENTIFIQUE
  ORGANISME_SPECTACLE_EXPOSITIONS
  PROJET_THESE_DOCTORAT
  SOCIETE_EXPOSITIONS_UNIVERSELLES
  SOCIETE_PROGRAMME_AUDIOVISUEL
  FONDATION_PATRIMOINE
  FONDS_DOTATION
  ORGANISME_AIDE_PME
  FEDERATION_ORGANISMES_AGREES
  ORGANISME_PROTECTION_BIENS_CULTURELS
  ORGANISME_UE_SIMILAIRE
}

enum Civilite {
  MME
  MLLE
  M
}

enum GroupeSanguin {
  A_POSITIF
  A_NEGATIF
  B_POSITIF
  B_NEGATIF
  AB_POSITIF
  AB_NEGATIF
  O_POSITIF
  O_NEGATIF
}

enum Sexe {
  HOMME
  FEMME
}

enum TailleTshirt {
  XS
  S
  M
  L
  XL
  XXL
  XXXL
}

// ─── Models ───────────────────────────────────────────────────────────────────

model Association {
  id                      String             @id @default(cuid())
  name                    String
  slug                    String             @unique
  city                    String?
  country                 String             @default("France")
  address                 String?
  phone                   String?
  website                 String?
  // Shown on devis/facture PDFs (below "Conditions de paiement") so the recipient knows
  // where to wire payment — distinct from BankAccount, which is for reconciliation import
  // and only ever stores a last-4, never a full IBAN.
  iban                    String?
  bic                     String?
  siren                   String?
  rna                     String?
  canIssueTaxReceipts     Boolean            @default(false)
  objet                   String?
  organismeCategory       OrganismeCategory  @default(ASSOCIATION_LOI_1901)
  organismeCategoryDetail String?
  // "groq" | "openai" | "mistral" — see src/lib/ai/client.ts SUPPORTED_PROVIDERS. Null
  // means the association hasn't configured BYOK yet (falls back to the platform's Groq
  // key, see platformClient in the same file).
  aiProvider              String?
  aiApiKey                String?
  aiModel                 String?
  smsAccountSid           String?
  smsAuthToken            String?
  smsPhoneNumber          String?
  livekitUrl              String?
  livekitApiKey           String?
  livekitApiSecret        String?
  stripeCustomerId        String?
  stripeSubscriptionId    String?
  stripeConnectId         String?
  plan                    AssociationPlan    @default(ESSENTIAL)
  // Staff-set override for negotiated "sur mesure" deals (see form-wise-app's pricing
  // page) — plan stays ESSENTIAL/PRO (still what Stripe actually bills), this just raises
  // the member cap enforced by assertMemberLimit() past what that tier normally allows.
  // Null means "use the tier's standard limit", not "unlimited".
  customMemberLimit       Int?
  // Brand identity applied to the dashboard, portal, devis/facture PDFs and the feuille
  // de présence PDF — separate from siteConfig's own logoUrl/primaryColor, which only
  // exist once the association has set up its public site. logoUrl/primaryColor also
  // seed the site builder's fields the first time it's opened.
  logoUrl                 String?
  // No DB default on purpose — a bare column default made every Pro association look
  // branded in this color (dashboard/portal theme, PDFs, emails) before the admin ever
  // opened the branding settings. null means "use the platform's own default theme";
  // the site builder and branding-settings UI supply #6366f1 as their own form default
  // instead, only persisted once the admin actually saves.
  primaryColor            String?
  secondaryColor          String?
  // Custom branding (logo + colors) defaults to Pro-only — see canUseCustomBranding() in
  // src/lib/plan-limits.ts. Same override pattern as customMemberLimit: null/false uses
  // the plan default, true force-enables it for an Essentiel association.
  customBrandingEnabled   Boolean?
  subscriptionStatus      SubscriptionStatus @default(TRIAL)
  trialEndsAt             DateTime?
  suspendedAt             DateTime?
  cancelAtPeriodEnd       Boolean            @default(false)
  currentPeriodEndsAt     DateTime?
  sitePublished           Boolean            @default(false)
  siteConfig              Json?
  modules                 Json?
  internalNotes           String?
  createdAt               DateTime           @default(now())
  updatedAt               DateTime           @updatedAt
  deletedAt               DateTime?

  users               User[]
  membres             Membre[]
  membreTypes         MembreType[]
  evenements          Evenement[]
  cotisations         Cotisation[]
  actualites          Actualite[]
  messageTemplates    MessageTemplate[]
  automationRules     AutomationRule[]
  materials           Material[]
  activityLogs        ActivityLog[]
  dons                Don[]
  sondages            Sondage[]
  boutiqueProduits    BoutiqueProduit[]
  boutiqueCommandes   BoutiqueCommande[]
  meetings            Meeting[]
  bankAccounts        BankAccount[]
  bankTransactions    BankTransaction[]
  financeCategories   FinanceCategory[]
  incomes             Income[]
  expenses            Expense[]
  bankReconciliations BankReconciliation[]
  fournisseurs        Fournisseur[]
  devis               Devis[]
  factures            Facture[]
  facturesRecues      FactureRecue[]
  emailMessages       EmailMessage[]
}

model User {
  id            String    @id @default(cuid())
  email         String
  name          String?
  passwordHash  String
  role          UserRole  @default(MEMBRE)
  active        Boolean   @default(true)
  associationId String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Set once, at signup, when the account is created via /register (see
  // src/lib/consent.ts and src/app/api/register/route.ts) — null for accounts created
  // any other way (admin-created members, portal self-registration) since those don't
  // go through the paid-signup consent step. termsVersion lets us know exactly which
  // revision of the CGS/politique de confidentialité was in effect when they agreed.
  termsAcceptedAt DateTime?
  termsVersion    String?
  termsAcceptedIp String?

  association         Association?         @relation(fields: [associationId], references: [id])
  notifications       Notification[]
  membre              Membre?
  passwordResetTokens PasswordResetToken[]

  @@unique([email, associationId])
  @@index([associationId, role])
}

model MembreType {
  id            String   @id @default(cuid())
  name          String
  description   String?
  color         String   @default("gray")
  associationId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  association Association @relation(fields: [associationId], references: [id])
  membres     Membre[]

  @@unique([name, associationId])
}

model Membre {
  id            String       @id @default(cuid())
  firstName     String
  lastName      String
  email         String?
  phone         String?
  birthDate     DateTime?
  address       String?
  civilite      Civilite?
  groupeSanguin GroupeSanguin?
  sexe          Sexe?
  allergies     String?
  photoUrl      String?
  possedeTshirt Boolean?
  tailleTshirt  TailleTshirt?
  status        MembreStatus @default(ACTIF)
  typeId        String?
  responsableId String?
  associationId String
  userId        String?      @unique
  joinedAt      DateTime     @default(now())
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  deletedAt     DateTime?

  // Set on the public membership-request form (src/components/site/sections/site-
  // membership-section.tsx), which creates a PENDING Membre with no User/password yet —
  // there's no User row to stamp consent on at that point, unlike the other signup flows
  // (see User.termsAcceptedAt). Left null for members created any other way (admin-added,
  // portal self-registration — those stamp the User instead).
  termsAcceptedAt DateTime?
  termsVersion    String?
  termsAcceptedIp String?

  association           Association          @relation(fields: [associationId], references: [id])
  user                  User?                @relation(fields: [userId], references: [id])
  type                  MembreType?          @relation(fields: [typeId], references: [id])
  responsable           Membre?              @relation("MembreResponsable", fields: [responsableId], references: [id], onDelete: SetNull)
  dependants            Membre[]             @relation("MembreResponsable")
  cotisations           Cotisation[]
  participations        Participation[]
  actualiteRecipients   ActualiteRecipient[]
  materialLoans         MaterialLoan[]
  automationLogs        AutomationLog[]
  dons                  Don[]
  sondageRecipients     SondageRecipient[]
  sondageReponses       SondageReponse[]
  boutiqueCommandes     BoutiqueCommande[]
  meetingsAsParticipant MeetingParticipant[]
  incomes               Income[]
  emailMessages         EmailMessage[]

  @@index([associationId, deletedAt])
  @@index([associationId, status])
}

model Evenement {
  id            String    @id @default(cuid())
  title         String
  description   String?
  date          DateTime
  endDate       DateTime?
  location      String?
  lat           Float?
  lng           Float?
  price         Decimal?  @db.Decimal(10, 2)
  capacity      Int?
  qrToken       String?   @unique
  qrExpiresAt   DateTime?
  associationId String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  association    Association     @relation(fields: [associationId], references: [id])
  participations Participation[]
  actualites     Actualite[]

  @@index([associationId, date])
}

model Participation {
  id              String      @id @default(cuid())
  membreId        String? // null = convive sans compte membre
  evenementId     String
  firstName       String // capturé sur la ligne — pas de join Membre pour l'affichage
  lastName        String
  email           String?
  present         Boolean     @default(false)
  rsvp            RsvpStatus?
  rsvpAt          DateTime?
  ticketPaidAt    DateTime?
  amount          Decimal?    @db.Decimal(10, 2) // montant payé pour CETTE place
  orderId         String? // regroupe les places d'une même réservation/paiement
  stripeSessionId String?
  createdAt       DateTime    @default(now())

  membre         Membre?         @relation(fields: [membreId], references: [id])
  evenement      Evenement       @relation(fields: [evenementId], references: [id])
  incomes        Income[]
  automationLogs AutomationLog[]

  @@index([evenementId])
  @@index([orderId])
  @@index([membreId, evenementId])
}

model Cotisation {
  id              String           @id @default(cuid())
  membreId        String
  associationId   String
  amount          Decimal          @db.Decimal(10, 2)
  year            Int
  paidAt          DateTime?
  status          CotisationStatus @default(EN_ATTENTE)
  note            String?
  stripeSessionId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  membre      Membre      @relation(fields: [membreId], references: [id])
  association Association @relation(fields: [associationId], references: [id])

  @@unique([membreId, year])
  @@index([associationId, status])
}

model Don {
  id              String    @id @default(cuid())
  associationId   String
  membreId        String?
  donorType       DonorType @default(INDIVIDUAL)
  firstName       String
  lastName        String
  companyName     String?
  siret           String?
  email           String
  address         String?
  amount          Decimal   @db.Decimal(10, 2)
  message         String?
  anonymous       Boolean   @default(false)
  receiptNumber   String?
  receiptIssuedAt DateTime?
  stripeSessionId String?   @unique
  paidAt          DateTime?
  refundedAt      DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  association Association @relation(fields: [associationId], references: [id])
  membre      Membre?     @relation(fields: [membreId], references: [id])

  @@unique([associationId, receiptNumber])
  @@index([associationId, paidAt])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String?
  link      String?
  read      Boolean  @default(false)
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId, read])
}

model Actualite {
  id            String    @id @default(cuid())
  associationId String
  title         String
  content       String
  imageUrl      String?
  pinned        Boolean   @default(false)
  publishedAt   DateTime?
  evenementId   String?
  recipientMode String    @default("ALL") // "ALL" | "SELECTED"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  association Association          @relation(fields: [associationId], references: [id])
  evenement   Evenement?           @relation(fields: [evenementId], references: [id])
  recipients  ActualiteRecipient[]

  @@index([associationId, publishedAt])
}

model ActualiteRecipient {
  actualiteId String
  membreId    String

  actualite Actualite @relation(fields: [actualiteId], references: [id], onDelete: Cascade)
  membre    Membre    @relation(fields: [membreId], references: [id])

  @@id([actualiteId, membreId])
}

model Material {
  id            String         @id @default(cuid())
  associationId String
  name          String
  category      String?
  categoryId    String?
  description   String?
  serialNumber  String?
  quantity      Int            @default(1)
  status        MaterialStatus @default(DISPONIBLE)
  location      String?
  purchaseDate  DateTime?
  purchasePrice Decimal?       @db.Decimal(10, 2)
  rentalRate    Decimal?       @db.Decimal(10, 2)
  imageUrl      String?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  association     Association      @relation(fields: [associationId], references: [id], onDelete: Cascade)
  financeCategory FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  loans           MaterialLoan[]

  @@index([associationId, status])
}

model MaterialLoan {
  id               String     @id @default(cuid())
  materialId       String
  membreId         String?
  borrowerName     String?
  quantity         Int        @default(1)
  status           LoanStatus @default(CONFIRME)
  borrowedAt       DateTime   @default(now())
  expectedReturnAt DateTime?
  returnedAt       DateTime?
  feeAmount        Decimal?   @db.Decimal(10, 2)
  notes            String?
  createdAt        DateTime   @default(now())

  material Material @relation(fields: [materialId], references: [id], onDelete: Cascade)
  membre   Membre?  @relation(fields: [membreId], references: [id])
  facture  Facture?

  @@index([materialId, returnedAt])
}

model MessageTemplate {
  id            String   @id @default(cuid())
  associationId String
  name          String
  category      String   @default("GENERAL")
  subject       String
  body          String   @db.Text
  smsBody       String?  @db.Text
  active        Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  association Association      @relation(fields: [associationId], references: [id], onDelete: Cascade)
  rules       AutomationRule[]
}

model AutomationRule {
  id            String         @id @default(cuid())
  associationId String
  name          String
  templateId    String
  triggerType   TriggerType
  triggerConfig Json
  channel       MessageChannel @default(EMAIL)
  recipients    String         @default("ALL")
  status        RuleStatus     @default(ACTIVE)
  lastRunAt     DateTime?
  nextRunAt     DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  association Association     @relation(fields: [associationId], references: [id], onDelete: Cascade)
  template    MessageTemplate @relation(fields: [templateId], references: [id])
  logs        AutomationLog[]

  @@index([associationId, status])
  @@index([status, nextRunAt])
}

model AutomationLog {
  id              String   @id @default(cuid())
  ruleId          String
  membreId        String?
  participationId String? // dedup key for EVENT_REMINDER targets that have no Membre (guests) — membreId alone can't identify them
  eventId         String?
  subject         String?
  sentAt          DateTime @default(now())

  rule          AutomationRule @relation(fields: [ruleId], references: [id], onDelete: Cascade)
  membre        Membre?        @relation(fields: [membreId], references: [id], onDelete: SetNull)
  participation Participation? @relation(fields: [participationId], references: [id], onDelete: SetNull)

  @@index([ruleId, sentAt])
  @@index([ruleId, eventId])
}

model ActivityLog {
  id            String   @id @default(cuid())
  associationId String
  actorId       String?
  action        String
  entity        String
  entityId      String?
  label         String?
  metadata      Json?
  createdAt     DateTime @default(now())

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  @@index([associationId, createdAt(sort: Desc)])
  @@index([associationId, entity])
}

model Sondage {
  id            String        @id @default(cuid())
  associationId String
  title         String
  description   String?
  status        SondageStatus @default(BROUILLON)
  recipientMode String        @default("ALL")
  anonymous     Boolean       @default(false)
  deadline      DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  association Association        @relation(fields: [associationId], references: [id], onDelete: Cascade)
  questions   SondageQuestion[]
  recipients  SondageRecipient[]
  reponses    SondageReponse[]

  @@index([associationId, status])
}

model SondageQuestion {
  id        String       @id @default(cuid())
  sondageId String
  type      QuestionType
  label     String
  required  Boolean      @default(false)
  order     Int
  options   Json?
  condition Json?

  sondage Sondage              @relation(fields: [sondageId], references: [id], onDelete: Cascade)
  items   SondageReponseItem[]
}

model SondageRecipient {
  sondageId String
  membreId  String

  sondage Sondage @relation(fields: [sondageId], references: [id], onDelete: Cascade)
  membre  Membre  @relation(fields: [membreId], references: [id], onDelete: Cascade)

  @@id([sondageId, membreId])
}

model SondageReponse {
  id          String   @id @default(cuid())
  sondageId   String
  membreId    String?
  submittedAt DateTime @default(now())

  sondage Sondage              @relation(fields: [sondageId], references: [id], onDelete: Cascade)
  membre  Membre?              @relation(fields: [membreId], references: [id], onDelete: SetNull)
  items   SondageReponseItem[]

  @@unique([sondageId, membreId])
}

model SondageReponseItem {
  id         String  @id @default(cuid())
  reponseId  String
  questionId String
  value      String?

  reponse  SondageReponse  @relation(fields: [reponseId], references: [id], onDelete: Cascade)
  question SondageQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

enum EmailStatus {
  QUEUED
  SENT
  DELIVERED
  OPENED
  CLICKED
  BOUNCED
  COMPLAINED
  DELAYED
  FAILED
}

model EmailMessage {
  id             String      @id @default(cuid())
  associationId  String
  membreId       String?
  resendId       String?     @unique
  to             String
  subject        String
  // Full rendered HTML, kept so the admin email log can show what was actually sent —
  // not reconstructible after the fact since templates are re-rendered with live data.
  html           String?     @db.Text
  // Attachments (e.g. Devis/Facture PDFs) aren't part of `html` and so never show up in
  // the admin preview — this flags that gap instead of letting the preview look complete.
  hasAttachments Boolean     @default(false)
  // "SONDAGE" | "AUTOMATION" | "BULK_MESSAGE" | "MEMBER_INVITE" | "MEETING_INVITE" |
  // "TRANSACTION" | "DOCUMENT" | "TEST" — kept as a String (not enum) so new sources
  // don't need a migration, matching the MessageTemplate.category convention.
  source         String
  sourceId       String?
  status         EmailStatus @default(QUEUED)
  errorMessage   String?
  sentAt         DateTime?
  deliveredAt    DateTime?
  openedAt       DateTime?
  clickedAt      DateTime?
  bouncedAt      DateTime?
  complainedAt   DateTime?
  createdAt      DateTime    @default(now())

  association Association @relation(fields: [associationId], references: [id], onDelete: Cascade)
  membre      Membre?     @relation(fields: [membreId], references: [id], onDelete: SetNull)

  @@index([associationId, membreId, createdAt(sort: Desc)])
  @@index([source, sourceId])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([email])
}

// ─── Boutique ─────────────────────────────────────────────────────────────────

model BoutiqueProduit {
  id            String                @id @default(cuid())
  associationId String
  categoryId    String?
  name          String
  description   String?
  imageUrl      String?
  status        BoutiqueProduitStatus @default(DRAFT)
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  association   Association            @relation(fields: [associationId], references: [id], onDelete: Cascade)
  category      FinanceCategory?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  variantes     BoutiqueVariante[]
  commandeItems BoutiqueCommandeItem[]
}

model BoutiqueVariante {
  id        String   @id @default(cuid())
  produitId String
  label     String
  price     Int
  stock     Int      @default(0)
  createdAt DateTime @default(now())

  produit       BoutiqueProduit        @relation(fields: [produitId], references: [id], onDelete: Cascade)
  commandeItems BoutiqueCommandeItem[]
}

model BoutiqueCommande {
  id                    String                 @id @default(cuid())
  associationId         String
  membreId              String?
  guestName             String?
  guestEmail            String?
  status                BoutiqueCommandeStatus @default(PENDING)
  paymentMethod         BoutiquePaymentMethod  @default(MANUAL)
  manualPaymentType     BoutiquePaymentMethod?
  // Assigned once, the moment the commande first becomes PAID — never reassigned by the
  // manualPaymentType correction flow, so a reçu already handed to a buyer keeps its number.
  receiptNumber         String?
  // Set once, the same moment as receiptNumber — kept separate from `updatedAt` because the
  // manualPaymentType correction flow updates the row after payment and must not make an
  // old sale look like it happened today (receipt PDF date, "Ventes récentes" ordering).
  paidAt                DateTime?
  stripePaymentIntentId String?
  totalAmount           Int
  note                  String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  association Association            @relation(fields: [associationId], references: [id], onDelete: Cascade)
  membre      Membre?                @relation(fields: [membreId], references: [id], onDelete: SetNull)
  items       BoutiqueCommandeItem[]

  @@unique([associationId, receiptNumber])
  @@index([associationId, status])
}

model BoutiqueCommandeItem {
  id         String  @id @default(cuid())
  commandeId String
  produitId  String
  varianteId String
  // Snapshot of BoutiqueProduit.categoryId taken when the item was ordered — recategorizing
  // a product later must not retroactively change how an already-placed order gets booked
  // to Finances once it's encaissé.
  categoryId String?
  quantity   Int
  unitPrice  Int

  commande BoutiqueCommande @relation(fields: [commandeId], references: [id], onDelete: Cascade)
  produit  BoutiqueProduit  @relation(fields: [produitId], references: [id], onDelete: Restrict)
  variante BoutiqueVariante @relation(fields: [varianteId], references: [id], onDelete: Restrict)
  category FinanceCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
}

// ─── Réunions ─────────────────────────────────────────────────────────────────

model Meeting {
  id               String        @id @default(cuid())
  associationId    String
  title            String
  description      String?
  status           MeetingStatus @default(SCHEDULED)
  type             MeetingType   @default(GENERALE)
  scheduledAt      DateTime?
  startedAt        DateTime?
  endedAt          DateTime?
  roomName         String        @unique
  createdById      String
  transcript       String?
  summary          String?
  egressId         String?
  recordingKey     String?
  // Snapshot of whichever LiveKit account (platform or the association's own) actually
  // created this meeting's room, pinned on first use — later changes to the association's
  // LiveKit settings must not point an in-progress/already-created meeting at a different
  // account than the one its room actually lives on.
  livekitUrl       String?
  livekitApiKey    String?
  livekitApiSecret String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  association  Association          @relation(fields: [associationId], references: [id], onDelete: Cascade)
  participants MeetingParticipant[]

  @@index([associationId])
}

model MeetingParticipant {
  id        String    @id @default(cuid())
  meetingId String
  membreId  String
  joinedAt  DateTime?

  meeting Meeting @relation(fields: [meetingId], references: [id], onDelete: Cascade)
  membre  Membre  @relation(fields: [membreId], references: [id], onDelete: Cascade)

  @@unique([meetingId, membreId])
}

// ─── Finances & Conciliation bancaire ────────────────────────────────────────

model BankAccount {
  id             String   @id @default(cuid())
  associationId  String
  bankName       String
  accountName    String
  ibanLast4      String?
  currency       String   @default("EUR")
  openingBalance Decimal  @default(0) @db.Decimal(10, 2)
  currentBalance Decimal  @default(0) @db.Decimal(10, 2)
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  association  Association       @relation(fields: [associationId], references: [id], onDelete: Cascade)
  transactions BankTransaction[]

  @@index([associationId])
}

model BankTransaction {
  id              String                @id @default(cuid())
  associationId   String
  bankAccountId   String
  transactionDate DateTime
  label           String
  amount          Decimal               @db.Decimal(10, 2)
  type            BankTransactionType
  balanceAfter    Decimal?              @db.Decimal(10, 2)
  externalId      String?
  status          BankTransactionStatus @default(UNMATCHED)
  rawData         Json?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  association     Association          @relation(fields: [associationId], references: [id], onDelete: Cascade)
  bankAccount     BankAccount          @relation(fields: [bankAccountId], references: [id], onDelete: Cascade)
  reconciliations BankReconciliation[]

  @@unique([bankAccountId, externalId])
  @@index([associationId, status])
  @@index([associationId, transactionDate])
}

model FinanceCategory {
  id             String              @id @default(cuid())
  associationId  String
  name           String
  type           FinanceCategoryType
  accountingCode String?
  isDefault      Boolean             @default(false)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  association           Association            @relation(fields: [associationId], references: [id], onDelete: Cascade)
  incomes               Income[]
  expenses              Expense[]
  boutiqueProduits      BoutiqueProduit[]
  boutiqueCommandeItems BoutiqueCommandeItem[]
  materials             Material[]

  @@index([associationId, type])
}

model Income {
  id                String       @id @default(cuid())
  associationId     String
  memberId          String?
  participationId   String? // the exact seat this income came from — lets a partial ticket cancellation remove precisely this row instead of guessing among an order's income rows
  facturePaymentId  String?      @unique // set when this row was auto-created from a Facture payment — see FacturePayment.income
  amount            Decimal      @db.Decimal(10, 2)
  categoryId        String?
  paymentMethod     String?
  date              DateTime
  description       String?
  source            IncomeSource @default(MANUAL)
  status            IncomeStatus @default(PENDING)
  reference         String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  association     Association          @relation(fields: [associationId], references: [id], onDelete: Cascade)
  membre          Membre?              @relation(fields: [memberId], references: [id], onDelete: SetNull)
  participation   Participation?       @relation(fields: [participationId], references: [id], onDelete: SetNull)
  facturePayment  FacturePayment?      @relation(fields: [facturePaymentId], references: [id], onDelete: SetNull)
  category        FinanceCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reconciliations BankReconciliation[]

  @@index([associationId, status])
  @@index([associationId, date])
}

model Expense {
  id             String        @id @default(cuid())
  associationId  String
  factureRecueId String?       @unique // set when this row was auto-created from a FactureRecue marked PAYEE — see FactureRecue.expense
  amount         Decimal       @db.Decimal(10, 2)
  categoryId     String?
  date           DateTime
  vendor         String?
  description    String?
  receiptUrl     String?
  internalNote   String?
  status         ExpenseStatus @default(DRAFT)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  association     Association          @relation(fields: [associationId], references: [id], onDelete: Cascade)
  factureRecue    FactureRecue?        @relation(fields: [factureRecueId], references: [id], onDelete: SetNull)
  category        FinanceCategory?     @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  reconciliations BankReconciliation[]

  @@index([associationId, status])
  @@index([associationId, date])
}

model BankReconciliation {
  id                String    @id @default(cuid())
  associationId     String
  bankTransactionId String    @unique
  incomeId          String?   @unique
  expenseId         String?   @unique
  matchScore        Int       @default(0)
  matchedBy         MatchedBy @default(AUTO)
  matchedAt         DateTime  @default(now())
  matchedByUserId   String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  association     Association     @relation(fields: [associationId], references: [id], onDelete: Cascade)
  bankTransaction BankTransaction @relation(fields: [bankTransactionId], references: [id], onDelete: Cascade)
  income          Income?         @relation(fields: [incomeId], references: [id], onDelete: SetNull)
  expense         Expense?        @relation(fields: [expenseId], references: [id], onDelete: SetNull)

  @@index([associationId])
}

enum FournisseurStatus {
  ACTIF
  INACTIF
  ARCHIVE
}

model Fournisseur {
  id            String            @id @default(cuid())
  associationId String
  companyName   String
  tradeName     String?
  contactName   String?
  contactRole   String?
  siret         String?
  siren         String?
  vatNumber     String?
  address       String?
  city          String?
  postalCode    String?
  country       String            @default("France")
  email         String?
  billingEmail  String?
  phone         String?
  website       String?
  category      String?
  status        FournisseurStatus @default(ACTIF)
  notes         String?
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  deletedAt     DateTime?

  association    Association    @relation(fields: [associationId], references: [id], onDelete: Cascade)
  devis          Devis[]
  factures       Facture[]
  facturesRecues FactureRecue[]

  @@index([associationId, status])
  @@index([associationId, deletedAt])
}

enum DevisStatus {
  BROUILLON
  ENVOYE
  ACCEPTE
  REFUSE
  EXPIRE
}

model Devis {
  id             String      @id @default(cuid())
  associationId  String
  fournisseurId  String?
  number         String
  status         DevisStatus @default(BROUILLON)
  issueDate      DateTime    @default(now())
  validUntil     DateTime?
  subtotal       Decimal     @db.Decimal(10, 2)
  vatAmount      Decimal     @default(0) @db.Decimal(10, 2)
  discountAmount Decimal     @default(0) @db.Decimal(10, 2)
  total          Decimal     @db.Decimal(10, 2)
  notes          String?
  paymentTerms   String?
  pdfUrl         String?
  sentAt         DateTime?
  respondedAt    DateTime?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  association Association  @relation(fields: [associationId], references: [id], onDelete: Cascade)
  fournisseur Fournisseur? @relation(fields: [fournisseurId], references: [id])
  items       DevisItem[]
  facture     Facture?

  @@unique([associationId, number])
  @@index([associationId, status])
  @@index([associationId, deletedAt])
}

model DevisItem {
  id          String  @id @default(cuid())
  devisId     String
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Decimal @default(0) @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  order       Int     @default(0)

  devis Devis @relation(fields: [devisId], references: [id], onDelete: Cascade)

  @@index([devisId])
}

enum FactureStatus {
  BROUILLON
  EN_ATTENTE
  PARTIELLEMENT_PAYEE
  PAYEE
  EN_RETARD
  ANNULEE
}

model Facture {
  id             String        @id @default(cuid())
  associationId  String
  fournisseurId  String?
  devisId        String?       @unique
  materialLoanId String?       @unique
  number         String
  status         FactureStatus @default(BROUILLON)
  issueDate      DateTime      @default(now())
  dueDate        DateTime?
  subtotal       Decimal       @db.Decimal(10, 2)
  vatAmount      Decimal       @default(0) @db.Decimal(10, 2)
  discountAmount Decimal       @default(0) @db.Decimal(10, 2)
  total          Decimal       @db.Decimal(10, 2)
  amountPaid     Decimal       @default(0) @db.Decimal(10, 2)
  notes          String?
  paymentTerms   String?
  pdfUrl         String?
  sentAt         DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  deletedAt      DateTime?

  association  Association      @relation(fields: [associationId], references: [id], onDelete: Cascade)
  fournisseur  Fournisseur?     @relation(fields: [fournisseurId], references: [id])
  devis        Devis?           @relation(fields: [devisId], references: [id])
  materialLoan MaterialLoan?    @relation(fields: [materialLoanId], references: [id], onDelete: SetNull)
  items        FactureItem[]
  payments     FacturePayment[]

  @@unique([associationId, number])
  @@index([associationId, status])
  @@index([associationId, dueDate])
  @@index([associationId, deletedAt])
}

model FactureItem {
  id          String  @id @default(cuid())
  factureId   String
  description String
  quantity    Decimal @db.Decimal(10, 2)
  unitPrice   Decimal @db.Decimal(10, 2)
  vatRate     Decimal @default(0) @db.Decimal(5, 2)
  discount    Decimal @default(0) @db.Decimal(10, 2)
  order       Int     @default(0)

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)

  @@index([factureId])
}

model FacturePayment {
  id        String   @id @default(cuid())
  factureId String
  amount    Decimal  @db.Decimal(10, 2)
  method    String
  paidAt    DateTime @default(now())
  note      String?
  createdAt DateTime @default(now())

  facture Facture @relation(fields: [factureId], references: [id], onDelete: Cascade)
  income  Income?

  @@index([factureId, paidAt])
}

enum FactureRecueStatus {
  A_PAYER
  PAYEE
  EN_LITIGE
  ANNULEE
}

model FactureRecue {
  id            String             @id @default(cuid())
  associationId String
  fournisseurId String?
  number        String?
  type          String // facture | devis_recu | comprovante | contrat | autre
  issueDate     DateTime
  amount        Decimal            @db.Decimal(10, 2)
  status        FactureRecueStatus @default(A_PAYER)
  fileUrl       String
  notes         String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  deletedAt     DateTime?

  association Association  @relation(fields: [associationId], references: [id], onDelete: Cascade)
  fournisseur Fournisseur? @relation(fields: [fournisseurId], references: [id])
  expense     Expense?

  @@index([associationId, status])
  @@index([associationId, deletedAt])
}
